# ============================================================
# 🔧 Internal Docs Q&A Agent — Environment Variables
# ============================================================
# Copy this to .env and fill in your actual values:
#   cp .env.example .env
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
DEBUG=true

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres123@localhost:5432/emp_docs_ai
DATABASE_URL_SYNC=postgresql://postgres:postgres123@localhost:5432/emp_docs_ai

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenAI ───────────────────────────────────────────────────
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── JWT Authentication ───────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Slack Bot (optional) ─────────────────────────────────────
# Get from: https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# ── Vector Store ─────────────────────────────────────────────
VECTOR_STORE_PATH=./vector_store
VECTOR_STORE_TYPE=chroma

# ── Embedding Model ─────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── LLM Model ───────────────────────────────────────────────
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1000

# ── Chunking ────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── Query ───────────────────────────────────────────────────
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.7

# ── Upload ──────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
